{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/prerender.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/api/prerender?type=blog&slug=$slug&path=/blog/:slug"
    },
    {
      "source": "/book/:slug", 
      "destination": "/api/prerender?type=book&slug=$slug&path=/book/:slug"
    },
    {
      "source": "/services",
      "destination": "/api/prerender?type=services&path=/services"
    },
    {
      "source": "/about",
      "destination": "/api/prerender?type=about&path=/about"
    },
    {
      "source": "/contact",
      "destination": "/api/prerender?type=contact&path=/contact"
    },
    {
      "source": "/turnaround-stories",
      "destination": "/api/prerender?type=turnaround&path=/turnaround-stories"
    },
    {
      "source": "/(.*)",
      "destination": "/api/prerender?type=home&path=$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options", 
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}